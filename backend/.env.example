# ============================================
# AquaVera Backend Environment Variables
# ============================================

# --- Hedera Testnet ---
# Network to use (always "testnet" for this project)
HEDERA_NETWORK=testnet
# Operator account ID created on portal.hedera.com (e.g., 0.0.12345)
HEDERA_OPERATOR_ID=
# Operator account private key (DER-encoded hex string)
HEDERA_OPERATOR_KEY=

# --- Hedera Token IDs (output by setup-hedera.ts) ---
# WSC fungible token ID (e.g., 0.0.12345)
WSC_TOKEN_ID=
# AVIC NFT collection token ID (e.g., 0.0.12346)
NFT_CERTIFICATE_TOKEN_ID=
# AVUSD stablecoin token ID (e.g., 0.0.12347)
AVUSD_TOKEN_ID=

# --- Hedera Topic IDs (output by setup-hedera.ts) ---
# Main platform HCS topic for audit logging
HCS_MAIN_TOPIC_ID=
# Dedicated HCS topics for each demo project's sensor data
HCS_PROJECT_TOPIC_1=
HCS_PROJECT_TOPIC_2=
HCS_PROJECT_TOPIC_3=

# --- Hedera File IDs (output by setup-hedera.ts) ---
# Guardian MRV policy schema stored on HFS
GUARDIAN_POLICY_FILE_ID=

# --- HSCS Smart Contract (output by setup-hedera.ts) ---
# AquaVeraEscrow contract ID on Hedera Testnet
ESCROW_CONTRACT_ID=

# --- Platform Identity ---
# Platform DID (created during setup)
PLATFORM_DID=
# Platform private key for signing VCs (can be same as operator key for testnet)
PLATFORM_PRIVATE_KEY=

# --- Platform Accounts ---
# Community fund Hedera account (receives 15% of trades)
COMMUNITY_FUND_ACCOUNT_ID=
# Platform treasury Hedera account (receives 7% of trades)
PLATFORM_TREASURY_ACCOUNT_ID=

# --- Server ---
# Port for the Express server
PORT=3001
# Frontend URL for CORS (use http://localhost:3000 for local dev)
FRONTEND_URL=http://localhost:3000
# Environment (development | production)
NODE_ENV=development

# --- Encryption ---
# AES encryption key for Hedera private keys (32-byte hex string)
ENCRYPTION_KEY=
